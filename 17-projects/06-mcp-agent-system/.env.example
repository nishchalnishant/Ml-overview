# Copy this file to .env and fill in your API keys.
# The project runs with only OPENAI_API_KEY set; others unlock extra features.

OPENAI_API_KEY=sk-...

# Optional: swap generation backend to Anthropic
ANTHROPIC_API_KEY=...

# Optional: used by server_github.py to read private repos
GITHUB_TOKEN=...

# Optional: for weather server. Leave blank to use free Open-Meteo (no key needed).
OPENWEATHERMAP_API_KEY=...
